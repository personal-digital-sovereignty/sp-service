# ===========================================
# sp-service — Environment Configuration
# ===========================================
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# -------------------------------------------
# Server Configuration
# -------------------------------------------
HOST=127.0.0.1
PORT=8080

# Environment (development, staging, production)
ENVIRONMENT=development

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# Path para o banco de dados SQLite
DATABASE_PATH=./data/sensus_nexus.db

# Workspace (Markdown Vault)
WORKSPACE_PATH=./data/vault

# -------------------------------------------
# Ollama Local Inference
# -------------------------------------------
OLLAMA_HOST=127.0.0.1:11434

# -------------------------------------------
# Cloud Providers (Opcional)
# Preencha apenas se for usar inferência em nuvem
# -------------------------------------------

# Alibaba Qwen / DashScope
QWEN_API_KEY=

# NVIDIA NIM / API Catalog
NVIDIA_API_KEY=

# OpenRouter (multi-model routing)
OPENROUTER_API_KEY=

# -------------------------------------------
# KMS & Security
# -------------------------------------------
# Chave mestra para criptografia (gerada automaticamente se ausente)
# Não modifique manualmente - use a API /v1/settings/kms
KMS_MASTER_KEY=

# -------------------------------------------
# Oracle Cloud Mesh (Opcional)
# -------------------------------------------
# Configuração para túnel SSH reverso
OCI_SSH_USER=
OCI_SSH_HOST=
OCI_SSH_PORT=22
OCI_SSH_KEY_PATH=~/.ssh/id_ed25519
OCI_REMOTE_OLLAMA_PORT=11434

# -------------------------------------------
# Telemetry & Logging
# -------------------------------------------
# Nível de log (trace, debug, info, warn, error)
LOG_LEVEL=info

# Enable/disable telemetry de hardware
HARDWARE_TELEMETRY=true

# -------------------------------------------
# Rate Limiting & Security
# -------------------------------------------
# Body limit global (em bytes) - padrão: 50MB
BODY_LIMIT_BYTES=52428800

# Timeout para requisições HTTP (em segundos)
HTTP_TIMEOUT_SECS=30

# -------------------------------------------
# RAG Pipeline Configuration
# -------------------------------------------
# Número máximo de chunks para retriever
RAG_TOP_K=5

# Threshold mínimo de similaridade para vetores
RAG_SIMILARITY_THRESHOLD=0.7

# -------------------------------------------
# Agentic Loop Configuration
# -------------------------------------------
# Enable/disable ReWOO por padrão
REWOO_ENABLED=false

# Enable/disable Deep Research por padrão
DEEP_RESEARCH_ENABLED=false

# Timeout máximo para tool calling (em segundos)
TOOL_CALL_TIMEOUT_SECS=120
